### 6.3 解析函数

```python
def parse_instruction(raw: str) -> Instruction:
    parts = raw.split()
    if not parts:
        raise VMSyntaxError("Empty instruction")
    op = parts[0]
    if op == "create":
        if len(parts) != 6:
            raise VMSyntaxError(f"create expects 6 args, got {len(parts)}")
        return CreateInstruction(parts[1], parts[2], parts[3], parts[4], parts[5])
    elif op == "exec":
        if len(parts) != 7:
            raise VMSyntaxError(f"exec expects 7 args, got {len(parts)}")
        return ExecInstruction(parts[1], parts[2], parts[3], parts[4], parts[5], parts[6])
    else:
        raise VMSyntaxError(f"Unknown instruction: {op}")
```

